# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=TenzorX Healthcare Navigator
DEBUG=false

# Longcat AI API Configuration
LONGCAT_API_KEY=your-longcat-api-key-here

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=https://tenzor-x.vercel.app/,http://localhost:3000,http://localhost:8000

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
